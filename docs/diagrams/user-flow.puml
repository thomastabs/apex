@startuml
title Apex — User Flow (Sequence)

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam sequence {
  ArrowColor #333333
  LifeLineBorderColor #9E9E9E
  LifeLineBackgroundColor #FAFAFA
  ParticipantBorderColor #666666
  ParticipantBackgroundColor #F5F5F5
  ActorBorderColor #666666
  ActorBackgroundColor #F5F5F5
  GroupBorderColor #B0B0B0
  DividerBackgroundColor #ECECEC
  DividerBorderColor #B0B0B0
}

actor User
participant "Frontend\n(Next.js)" as FE
participant "FastAPI\nBackend" as BE
participant "AI Engine\n(Claude)" as AI
participant "PM Tool\n(Taiga/Jira)" as PM
participant "GitHub\n(Actions / webhook)" as GH
database "Spec Store\n(contextspec)" as ST

== Phase 1 · Requirements ==
User -> FE : select epic / project concept
FE -> BE : POST /phase1/generate
activate BE
BE -> AI : generate NL stories
activate AI
AI --> BE : story drafts
deactivate AI
BE --> FE : drafts
deactivate BE
FE --> User : review & edit (human gate)
User -> FE : approve → compile
FE -> BE : POST /phase1/compile
activate BE
BE -> AI : compile Gherkin + EARS constraints
activate AI
AI --> BE : Gherkin + constraints
deactivate AI
BE -> PM : push approved stories
BE -> ST : lock functional-spec  (gherkin_locked)
deactivate BE

== Phase 2 · Design ==
User -> FE : lock tech stack (Gate 0)
FE -> BE : POST /phase2/design
activate BE
BE -> ST : read locked stories
BE -> AI : generate design bundle
activate AI
AI --> BE : screens · flows · specs
deactivate AI
BE --> FE : design draft
deactivate BE
FE --> User : review & edit (no role-gated sign-off — anyone locks it themselves)
User -> FE : Save & Lock Design
FE -> BE : lock design
activate BE
BE -> ST : lock design artefacts  (design_locked)
deactivate BE

== Phase 3 · Implementation Assist ==
User -> FE : select story
FE -> BE : POST /phase3/tasks
activate BE
BE -> AI : break into tasks + developer packs
activate AI
AI --> BE : tasks + packs
deactivate AI
BE --> FE : task breakdown
deactivate BE
FE --> User : review & edit tasks
User -> FE : generate + save developer pack
FE -> BE : save pack
activate BE
BE -> ST : record Bolt status  (pack_ready)
deactivate BE
User -> FE : push tasks
FE -> BE : push tasks (via Taiga/Jira proxy)
BE -> PM : create subtasks
BE -> ST : record Bolt status  (pushed)
User -> FE : Mark Bolt Done (Phase 3 or the Bolts page)
FE -> BE : record Bolt status  (done)
activate BE
BE -> ST : Bolt Cycle Time sample  (pack_ready → done)
deactivate BE
FE -> BE : lock story
activate BE
BE -> ST : lock story  (implementation)
deactivate BE

== Phase 4 · Testing ==
User -> FE : select story to test
FE -> BE : POST /phase4/plan
activate BE
BE -> AI : generate test plan
activate AI
AI --> BE : scenarios
deactivate AI
BE --> FE : test plan
deactivate BE
User -> FE : execute scenarios (pass/fail)
alt all scenarios pass
  FE -> BE : lock qa_passed
  BE -> ST : qa_passed
else failure
  FE -> BE : Bug Isolation Wizard
  activate BE
  BE -> AI : Fix-Bolt vaccine + bug report
  activate AI
  AI --> BE : vaccine
  deactivate AI
  BE -> ST : vaccines.md  (re-enters Phase 4)
  deactivate BE
end

== Phase 5 · Deployment ==
User -> FE : select QA-passed story
FE -> BE : POST /phase5/preflight
activate BE
BE -> AI : infra delta + traceability matrix
activate AI
AI --> BE : deploy pack (if infra changed)
deactivate AI
BE --> FE : pre-flight + Deployment Gate
deactivate BE
FE --> User : Deployment Gate (Tech Lead + Security Reviewer sign-off)
User -> FE : approve
alt manual deployment
  FE -> BE : record manual deployment
  activate BE
  BE -> ST : deployment-log.md  (deployed)
  deactivate BE
else GitHub Actions dispatch
  FE -> BE : dispatch workflow (confirmed)
  activate BE
  BE -> GH : trigger existing workflow
  deactivate BE
  GH -> BE : workflow_run completed (webhook)
  activate BE
  BE -> ST : deployment-log.md  (deployed only if conclusion: success)
  deactivate BE
end

== Phase 6 · Maintenance (Spec Drift + Feedback Routing) ==
group Feedback Routing
  User -> FE : maintenance event (manual · GitHub Issues · Taiga Issues)
  FE -> BE : POST /phase6/triage
  activate BE
  BE -> AI : classify + narrow-context diagnosis
  activate AI
  AI --> BE : change-request | bug + severity
  deactivate AI
  alt change request (business deviation)
    BE -> ST : route to Phase 1 discovery — never patched directly
  else bug (technical deviation) — severity routing
    BE -> ST : Fast Lane → deploy  /  Secure Lane → Phase 4 (Regression Bypass)
  end
  deactivate BE
end

group Spec Drift (spec↔code conformance)
  User -> FE : verify story / scan for regressions
  FE -> BE : POST /phase6/conformance
  activate BE
  BE -> ST : deterministic Layer A (endpoints · scenarios · constraints · runtime)
  BE -> AI : Layer B confirms/corrects, optional adversarial panel
  activate AI
  AI --> BE : per-row verdicts + citations
  deactivate AI
  BE -> ST : conformance report + score (code-computed, never AI)
  alt regression detected
    BE -> ST : flag conformance_regressed / trace_flag → suggest re-open source phase
  end
  deactivate BE
end

@enduml
